# Gemini API Key (preferred)
GEMINI_API_KEY=your_gemini_api_key

# Optional model override
GEMINI_MODEL=gemini-2.5-flash

# Alternative key name supported by Vite default prefix
VITE_GEMINI_API_KEY=your_gemini_api_key

# Eval mode: offline = only local rules, no AI call (default)
#            online  = also call Gemini API
EVAL_MODE=offline
